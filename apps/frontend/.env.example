# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DB_NAME

# NextAuth (required)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=

# App URL for NextAuth callbacks (required in production)
NEXTAUTH_URL=http://localhost:3000

# Resend API key for password-reset emails (optional for local dev)
RESEND_API_KEY=

# Base64-encoded 32-byte encryption key for credentials (required)
ENCRYPTION_KEY=

# S3-compatible object storage (required for media uploads)
# Cloudflare R2 example endpoint: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Use "auto" for Cloudflare R2
S3_REGION=auto
S3_BUCKET_NAME=
# Public URL prefix for uploaded files (no trailing slash)
# Example: https://media.example.com or https://pub-<hash>.r2.dev
S3_PUBLIC_BASE_URL=
